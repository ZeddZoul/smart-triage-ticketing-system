# =============================================================================
# Smart Triage Ticketing System — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values.
# See REQUIREMENTS.md §5.1 for full documentation.
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# REQUIRED: MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/smart-triage

# ── Authentication ───────────────────────────────────────────────────────────
# REQUIRED: Secret key for signing JWT tokens (use a strong random string)
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRES_IN=24h
BCRYPT_SALT_ROUNDS=10

# ── AI Triage (Google Gemini) ────────────────────────────────────────────────
# REQUIRED: Your Google Gemini API key
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
MAX_TRIAGE_RETRIES=3

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
